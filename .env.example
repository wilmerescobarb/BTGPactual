# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# ─────────────────────────────────────────────────────────────────────────────

# Tu usuario de Docker Hub (ej: miusuario)
DOCKERHUB_USERNAME=miusuario

# JWT — debe ser el mismo en todos los microservicios
JWT_SECRET=bgt-super-secret-key-for-jwt-signing-2026

# Gmail (cuenta que envía notificaciones por email)
MAIL_USERNAME=usuario@ceiba.com.co
MAIL_PASSWORD='#### #### #### ####'   # App Password de Google

# AWS SNS (envío de SMS)
AWS_ACCESS_KEY=TU_AWS_ACCESS_KEY
AWS_SECRET_KEY=TU_AWS_SECRET_KEY
AWS_REGION=us-east-1
